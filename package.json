{
  "name": "nestjs-fastify-api-boilerplate",
  "version": "0.1.0-alpha.1",
  "description": "Production-ready modular REST API boilerplate built with NestJS, Fastify, Prisma, and Zod.",
  "author": "AutanaSoft <github@autanasoft.com>",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/AutanaSoft/nestjs-fastify-api-boilerplate.git"
  },
  "bugs": {
    "url": "https://github.com/AutanaSoft/nestjs-fastify-api-boilerplate/issues",
    "email": "github@autanasoft.com"
  },
  "homepage": "https://github.com/AutanaSoft/nestjs-fastify-api-boilerplate#readme",
  "prisma": {
    "seed": "ts-node src/modules/database/prisma/seed/index.ts"
  },
  "scripts": {
    "start:dev": "nest start --watch",
    "build": "nest build",
    "start": "nest start",
    "start:prod": "node dist/main",
    "start:debug": "nest start --debug --watch",
    "test": "rimraf coverage .tmp && NODE_OPTIONS=\"--experimental-vm-modules --disable-warning=ExperimentalWarning\" jest --coverage",
    "test:e2e": "NODE_OPTIONS=\"--experimental-vm-modules --disable-warning=ExperimentalWarning\" jest --selectProjects e2e --coverage",
    "test:unit": "jest --selectProjects unit --coverage",
    "lint": "eslint \"{src,test}/**/*.{ts,tsx,js,jsx}\" --fix",
    "format": "prettier --write \"src/**/*\" \"test/**/*\"",
    "prepare": "husky",
    "email:dev": "email dev --dir src/modules/email/templates --port 3001",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:seed": "ts-node src/modules/database/prisma/seed/index.ts",
    "prisma:reset": "prisma migrate reset"
  },
  "dependencies": {
    "@fastify/static": "^9.0.0",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.1.17",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.17",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/microservices": "^11.1.17",
    "@nestjs/platform-fastify": "^11.1.17",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/terminus": "^11.1.1",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@react-email/components": "^1.0.10",
    "@react-email/render": "^2.0.4",
    "axios": "^1.14.0",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.3.1",
    "fastify": "5.8.4",
    "ioredis": "^5.10.1",
    "nestjs-pino": "^4.6.1",
    "nestjs-zod": "^5.2.1",
    "nodemailer": "^8.0.4",
    "pg": "^8.20.0",
    "pino-http": "^11.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.9.4",
    "rxjs": "^7.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@darraghor/eslint-plugin-nestjs-typed": "^7.1.27",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.17",
    "@react-email/preview-server": "5.2.10",
    "@swc/cli": "^0.7.0",
    "@swc/core": "^1.15.21",
    "@swc/jest": "^0.2.39",
    "@types/bcrypt": "^6.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "lint-staged": "^16.4.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "prisma": "^7.6.0",
    "react-email": "^5.2.10",
    "rimraf": "^6.1.3",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2"
  }
}
