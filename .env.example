# Application
APP_NAME=NestJS API REST FULL
APP_DESCRIPTION=NestJS API REST FULL
APP_VERSION=2.0.0
APP_PORT=4200
APP_HOST=localhost
APP_GLOBAL_PREFIX=
APP_LOG_LEVEL=debug
APP_CORRELATION_ID=x-correlation-id
APP_FRONTEND_URL=http://localhost:4200

# Swagger
SWAGGER_ENABLED=true
SWAGGER_PATH=docs
SWAGGER_VERSION=1.0.0

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Auth
AUTH_JWT_SECRET=replace-with-a-secure-secret-with-at-least-32-characters
AUTH_JWT_ISSUER=nestjs-fastify-api-boilerplate
AUTH_JWT_AUDIENCE=nestjs-fastify-api-boilerplate-client
AUTH_ACCESS_TOKEN_TTL=1d
AUTH_REFRESH_TOKEN_TTL=7d
AUTH_VERIFY_EMAIL_TOKEN_TTL=1d
AUTH_RESET_PASSWORD_TOKEN_TTL=1d
AUTH_ARGON2_MEMORY_COST=19456
AUTH_ARGON2_TIME_COST=2
AUTH_ARGON2_PARALLELISM=1
AUTH_ARGON2_HASH_LENGTH=32

# Resend / SMTP options are now stored in the database AppSetting table under 'EMAIL_SETTINGS'.

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/nestjs-fastify-api-boilerplate?schema=public"
