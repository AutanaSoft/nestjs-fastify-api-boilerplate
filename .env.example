# Application
APP_NAME=NestJS API REST FULL
APP_DESCRIPTION=NestJS API REST FULL
APP_VERSION=2.0.0
APP_PORT=4200
APP_HOST=localhost
APP_GLOBAL_PREFIX=
APP_LOG_LEVEL=debug
APP_CORRELATION_ID=x-correlation-id
APP_FRONTEND_URL=http://localhost:3000

# Swagger
SWAGGER_ENABLED=true
SWAGGER_PATH=docs
SWAGGER_VERSION=1.0.0

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Resend / SMTP options are now stored in the database AppSetting table under 'EMAIL_SETTINGS'.

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/autanasoft_db?schema=public"
